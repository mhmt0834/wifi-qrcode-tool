{
	"bsonType": "object",
	"description": "WiFi自由免广告特权申请",
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": { "description": "文档 ID" },
		"openid": { "bsonType": "string", "title": "用户OpenID" },
		"benefitKey": { "bsonType": "string", "title": "福利标识" },
		"privilegeType": { "bsonType": "string", "title": "特权类型" },
		"level": { "bsonType": "string", "title": "特权等级", "enum": ["monthly", "permanent"] },
		"title": { "bsonType": "string", "title": "申请标题" },
		"requiredCount": { "bsonType": "int", "title": "所需观看次数" },
		"watchCount": { "bsonType": "int", "title": "提交时观看次数" },
		"dateKey": { "bsonType": "string", "title": "申请日期" },
		"status": { "bsonType": "string", "title": "状态", "enum": ["pending", "approved", "rejected"] },
		"privilegeId": { "bsonType": "string", "title": "生效特权ID" },
		"auditorOpenid": { "bsonType": "string", "title": "审核人OpenID" },
		"auditNote": { "bsonType": "string", "title": "审核备注" },
		"auditTime": { "bsonType": "timestamp", "title": "审核时间" },
		"rejectTime": { "bsonType": "timestamp", "title": "驳回时间" },
		"createTime": { "bsonType": "timestamp", "title": "创建时间" },
		"updateTime": { "bsonType": "timestamp", "title": "更新时间" }
	}
}
