{
	"bsonType": "object",
	"description": "商家收益明细",
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": { "description": "文档 ID" },
		"adEventId": { "bsonType": "string", "title": "激励广告事件ID" },
		"merchantOpenid": { "bsonType": "string", "title": "商家OpenID" },
		"agentOpenid": { "bsonType": "string", "title": "合伙人OpenID" },
		"wifiId": { "bsonType": "string", "title": "WiFi文档ID" },
		"wifiName": { "bsonType": "string", "title": "WiFi名称" },
		"title": { "bsonType": "string", "title": "收益标题" },
		"amount": { "bsonType": "double", "title": "商家金额/提现金额(元)" },
		"adType": { "bsonType": "string", "title": "广告类型" },
		"adUnitId": { "bsonType": "string", "title": "广告位ID" },
		"grossAmount": { "bsonType": "double", "title": "广告总收入(元)" },
		"platformAmount": { "bsonType": "double", "title": "平台分成(元)" },
		"agentAmount": { "bsonType": "double", "title": "合伙人预留分成(元)" },
		"merchantAmount": { "bsonType": "double", "title": "商家分成(元)" },
		"type": { "bsonType": "string", "title": "类型", "enum": ["ad", "withdraw"] },
		"status": { "bsonType": "string", "title": "状态", "enum": ["estimated", "settled", "pending", "approved", "paid", "rejected"] },
		"settlementId": { "bsonType": "string", "title": "结算批次ID" },
		"settleDate": { "bsonType": "string", "title": "结算日期" },
		"settleTime": { "bsonType": "timestamp", "title": "结算时间" },
		"auditorOpenid": { "bsonType": "string", "title": "审核人OpenID" },
		"auditNote": { "bsonType": "string", "title": "审核备注" },
		"auditTime": { "bsonType": "timestamp", "title": "审核时间" },
		"rejectTime": { "bsonType": "timestamp", "title": "驳回时间" },
		"payerOpenid": { "bsonType": "string", "title": "打款人OpenID" },
		"payNote": { "bsonType": "string", "title": "打款备注" },
		"payTime": { "bsonType": "timestamp", "title": "打款时间" },
		"updateTime": { "bsonType": "timestamp", "title": "更新时间" },
		"createTime": { "bsonType": "timestamp", "title": "创建时间" }
	}
}
